<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <property name="hibernate.connection.driver_class">org.h2.Driver</property>
        <property name="hibernate.connection.url">jdbc:h2:file:./data/jobplatform_db;AUTO_SERVER=TRUE</property>
        <property name="hibernate.connection.username">sa</property>
        <property name="hibernate.connection.password"></property>

        <property name="hibernate.dialect">org.hibernate.dialect.H2Dialect</property>

        <property name="hibernate.hbm2ddl.auto">update</property>

        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <mapping class="jobplatform.model.PlatformUser"/>
        <mapping class="jobplatform.model.JobSeeker"/>
        <mapping class="jobplatform.model.Employer"/>
        <mapping class="jobplatform.model.Company"/>
        <mapping class="jobplatform.model.CandidateProfile"/>
        <mapping class="jobplatform.model.CV"/>
        <mapping class="jobplatform.model.Skill"/>
        <mapping class="jobplatform.model.CandidateSkill"/>
        <mapping class="jobplatform.model.JobOffer"/>
        <mapping class="jobplatform.model.PermanentOffer"/>
        <mapping class="jobplatform.model.ContractOffer"/>
        <mapping class="jobplatform.model.FreelanceOffer"/>
        <mapping class="jobplatform.model.Application"/>
        <mapping class="jobplatform.model.SavedOffer"/>
        <mapping class="jobplatform.model.Notification"/>
        <mapping class="jobplatform.model.Interview"/>
        <mapping class="jobplatform.model.RecruitmentProcess"/>
        <mapping class="jobplatform.model.RecruitmentStage"/>

    </session-factory>
</hibernate-configuration>